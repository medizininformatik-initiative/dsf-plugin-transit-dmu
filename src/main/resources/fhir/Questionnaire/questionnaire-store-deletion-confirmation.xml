<Questionnaire xmlns="http://hl7.org/fhir">
	<meta>
		<profile value="http://dsf.dev/fhir/StructureDefinition/questionnaire|1.5.0"/>
		<tag>
			<system value="http://dsf.dev/fhir/CodeSystem/read-access-tag"/>
			<code value="ALL"/>
		</tag>
	</meta>
	<url value="http://medizininformatik-initiative.de/fhir/Questionnaire/store-deletion-confirmation"/>
	<!-- version managed by bpe -->
	<version value="#{version}"/>
	<!-- date managed by bpe -->
	<date value="#{date}"/>
	<!-- status managed by bpe -->
	<status value="unknown"/>
	<item>
		<linkId value="business-key"/>
		<type value="string"/>
		<text value="The business-key of the process execution"/>
		<required value="true"/>
	</item>
	<item>
		<linkId value="user-task-id"/>
		<type value="string"/>
		<text value="The user-task-id of the process execution"/>
		<required value="true"/>
	</item>
	<item>
		<linkId value="project-identifier"/>
		<type value="string"/>
		<text value="The project identifier"/>
		<required value="true"/>
	</item>
	<item>
		<linkId value="store-deletion-confirmation"/>
		<type value="boolean"/>
		<text value="Please confirm that the FHIR-Store can be deleted"/>
		<required value="true"/>
	</item>
</Questionnaire>