<Task xmlns="http://hl7.org/fhir">
    <meta>
        <profile value="http://datamanagementunit.eu/fhir/StructureDefinition/task-delete-store|#{version}"/>
    </meta>
    <instantiatesCanonical value="http://datamanagementunit.eu/bpe/Process/storeControllerDelete|#{version}"/>
    <status value="requested"/>
    <intent value="order"/>
    <authoredOn value="#{date}"/>
    <requester>
        <type value="Organization"/>
        <identifier>
            <system value="http://dsf.dev/sid/organization-identifier"/>
            <value value="#{requester}"/>
        </identifier>
    </requester>
    <restriction>
        <recipient>
            <type value="Organization"/>
            <identifier>
                <system value="http://dsf.dev/sid/organization-identifier"/>
                <value value="#{recipient}"/>
            </identifier>
        </recipient>
    </restriction>
    <input>
        <type>
            <coding>
                <system value="http://dsf.dev/fhir/CodeSystem/bpmn-message"/>
                <code value="message-name"/>
            </coding>
        </type>
        <valueString value="deleteFhirStore"/>
    </input>
    <input>
        <type>
            <coding>
                <system value="http://dsf.dev/fhir/CodeSystem/bpmn-message"/>
                <code value="business-key"/>
            </coding>
        </type>
        <valueString value="#{business-key}"/>
    </input>
    <input>
        <type>
            <coding>
                <system value="http://medizininformatik-initiative.de/fhir/CodeSystem/data-sharing"/>
                <code value="project-identifier"/>
            </coding>
        </type>
        <valueIdentifier>
            <system value="http://medizininformatik-initiative.de/sid/project-identifier"/>
            <value value="#{project-identifier}"/> </valueIdentifier>
    </input>
</Task>
